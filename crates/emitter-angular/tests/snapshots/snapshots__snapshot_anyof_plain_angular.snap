@Injectable({ providedIn: 'root' })
export class ApiService {
  constructor(private http: HttpClient) {}

  search(body: searchBody): Observable<searchResponse> {
    return this.http.post<searchResponse>(`/search`, body);
  }

  listNotifications(): Observable<listNotificationsResponse> {
    return this.http.get<listNotificationsResponse>(`/notifications`);
  }

}
