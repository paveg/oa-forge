import axios from 'axios';

let _instance: AxiosInstance = axios.create();

export function setAxiosInstance(instance: AxiosInstance) {
  _instance = instance;
}

type ArrayStyle = 'comma' | 'multi' | 'brackets';

function buildQuery(
  params?: Record<string, unknown>,
  arrayStyles?: Record<string, ArrayStyle>,
): string {
  if (!params) return '';
  const parts: string[] = [];
  for (const [key, value] of Object.entries(params)) {
    if (value === undefined) continue;
    if (Array.isArray(value)) {
      const style = arrayStyles?.[key] ?? 'multi';
      if (style === 'comma') {
        parts.push(`${encodeURIComponent(key)}=${value.map(v => encodeURIComponent(String(v))).join(',')}`);
      } else if (style === 'brackets') {
        for (const v of value) parts.push(`${encodeURIComponent(key + '[]')}=${encodeURIComponent(String(v))}`);
      } else {
        for (const v of value) parts.push(`${encodeURIComponent(key)}=${encodeURIComponent(String(v))}`);
      }
    } else {
      parts.push(`${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`);
    }
  }
  return parts.length > 0 ? '?' + parts.join('&') : '';
}

export async function listResources(queryParams?: listResourcesQueryParams, headerParams: listResourcesHeaderParams, config?: AxiosRequestConfig): Promise<listResourcesResponse> {
  const _config: AxiosRequestConfig = { ...config, headers: { ...config?.headers, ...headerParams as Record<string, string> } };
  const { data } = await _instance.get<listResourcesResponse>(`/resources${buildQuery(queryParams as Record<string, unknown>)}`, _config);
  return data;
}

export async function getResource(pathParams: getResourcePathParams, headerParams: getResourceHeaderParams, cookieParams: getResourceCookieParams, config?: AxiosRequestConfig): Promise<getResourceResponse> {
  const _config: AxiosRequestConfig = { ...config, headers: { ...config?.headers, ...headerParams as Record<string, string>, Cookie: Object.entries(cookieParams).filter(([, v]) => v !== undefined).map(([k, v]) => `${k}=${v}`).join('; ') } };
  const { data } = await _instance.get<getResourceResponse>(`/resources/${pathParams.resourceId}`, _config);
