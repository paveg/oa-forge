@Injectable({ providedIn: 'root' })
export class ApiService {
  constructor(private http: HttpClient) {}

  listResources(queryParams?: listResourcesQueryParams): Observable<listResourcesResponse> {
    let params = new HttpParams();
    if (queryParams) {
      for (const [key, value] of Object.entries(queryParams)) {
        if (value !== undefined) params = params.set(key, String(value));
      }
    }
    return this.http.get<listResourcesResponse>(`/resources`, {{ params }});
  }

  getResource(pathParams: getResourcePathParams): Observable<getResourceResponse> {
    return this.http.get<getResourceResponse>(`/resources/${pathParams.resourceId}`);
  }

}
