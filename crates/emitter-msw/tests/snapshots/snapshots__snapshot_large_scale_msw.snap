  return http.post('/auth/password/reset', () => {
    return new HttpResponse(null, { status: 204 });
  });
}

export function resetPasswordHandler(override?: undefined | (() => undefined)) {
  return http.post('/auth/password/reset/:token', () => {
    return new HttpResponse(null, { status: 204 });
  });
}

export function getCurrentUserHandler(override?: Types.getCurrentUserResponse | (() => Types.getCurrentUserResponse)) {
  return http.get('/auth/me', () => {
    const data = typeof override === 'function' ? override() : override;
    return HttpResponse.json(data ?? {});
  });
}

