import type { uploadFileResponse, uploadFileBody, listItemsQueryParams, listItemsResponse, listCursoredQueryParams, listCursoredResponse, updateTextBody } from './types.gen';

export type CustomClient = (
  method: string,
  url: string,
  options?: {
    headers?: Record<string, string>;
    body?: unknown;
    signal?: AbortSignal;
  },
) => Promise<unknown>;

type ArrayStyle = 'comma' | 'multi' | 'brackets';

function buildQuery(
  params?: Record<string, unknown>,
  arrayStyles?: Record<string, ArrayStyle>,
): string {
  if (!params) return '';
  const parts: string[] = [];
  for (const [key, value] of Object.entries(params)) {
    if (value === undefined) continue;
    if (Array.isArray(value)) {
      const style = arrayStyles?.[key] ?? 'multi';
      if (style === 'comma') {
        parts.push(`${encodeURIComponent(key)}=${value.map(v => encodeURIComponent(String(v))).join(',')}`);
      } else if (style === 'brackets') {
        for (const v of value) parts.push(`${encodeURIComponent(key + '[]')}=${encodeURIComponent(String(v))}`);
      } else {
        for (const v of value) parts.push(`${encodeURIComponent(key)}=${encodeURIComponent(String(v))}`);
      }
    } else {
      parts.push(`${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`);
    }
  }
  return parts.length > 0 ? '?' + parts.join('&') : '';
}

export function uploadFile(client: CustomClient, body: uploadFileBody): Promise<uploadFileResponse> {
  return client('POST', `/upload`, {
    body: (() => {
      const fd = new FormData();
      for (const [k, v] of Object.entries(body as Record<string, unknown>)) {
        if (v instanceof Blob) fd.append(k, v);
        else if (v !== undefined) fd.append(k, String(v));
      }
      return fd;
    })(),
  }) as Promise<uploadFileResponse>;
}

export function listItems(client: CustomClient, queryParams?: listItemsQueryParams): Promise<listItemsResponse> {
  return client('GET', `/items${buildQuery(queryParams as Record<string, unknown>)}`) as Promise<listItemsResponse>;
}

export function listCursored(client: CustomClient, queryParams?: listCursoredQueryParams): Promise<listCursoredResponse> {
  return client('GET', `/cursored${buildQuery(queryParams as Record<string, unknown>)}`) as Promise<listCursoredResponse>;
}

export function updateText(client: CustomClient, body: updateTextBody): Promise<void> {
  return client('PUT', `/text-upload`, {
    headers: { 'Content-Type': 'text/plain' },
    body: String(body),
  }) as Promise<void>;
}
