import type { getStatusResponse, echoResponse, echoBody, getConfigResponse, getConfigError, getItemHistoryPathParams, getItemHistoryResponse } from './types.gen';
import type { AxiosInstance, AxiosRequestConfig } from 'axios';
import axios from 'axios';

let _instance: AxiosInstance = axios.create();

export function setAxiosInstance(instance: AxiosInstance) {
  _instance = instance;
}

type ArrayStyle = 'comma' | 'multi' | 'brackets';

function buildQuery(
  params?: Record<string, unknown>,
  arrayStyles?: Record<string, ArrayStyle>,
): string {
  if (!params) return '';
  const parts: string[] = [];
  for (const [key, value] of Object.entries(params)) {
    if (value === undefined) continue;
    if (Array.isArray(value)) {
      const style = arrayStyles?.[key] ?? 'multi';
      if (style === 'comma') {
        parts.push(`${encodeURIComponent(key)}=${value.map(v => encodeURIComponent(String(v))).join(',')}`);
      } else if (style === 'brackets') {
        for (const v of value) parts.push(`${encodeURIComponent(key + '[]')}=${encodeURIComponent(String(v))}`);
      } else {
        for (const v of value) parts.push(`${encodeURIComponent(key)}=${encodeURIComponent(String(v))}`);
      }
    } else {
      parts.push(`${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`);
    }
  }
  return parts.length > 0 ? '?' + parts.join('&') : '';
}

export async function getStatus(config?: AxiosRequestConfig): Promise<getStatusResponse> {
  const { data } = await _instance.get<getStatusResponse>(`/status`, config);
  return data;
}

export async function echo(body: echoBody, config?: AxiosRequestConfig): Promise<echoResponse> {
  const { data } = await _instance.post<echoResponse>(`/echo`, body, config);
  return data;
}

export async function getConfig(config?: AxiosRequestConfig): Promise<getConfigResponse> {
  const { data } = await _instance.get<getConfigResponse>(`/config`, config);
  return data;
}

export async function getItemHistory(pathParams: getItemHistoryPathParams, config?: AxiosRequestConfig): Promise<getItemHistoryResponse> {
  const { data } = await _instance.get<getItemHistoryResponse>(`/items/${pathParams.itemId}/history`, config);
  return data;
}
